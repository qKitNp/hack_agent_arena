# Copy to .env and set ONE provider key below + the matching MODEL (see README).
# The agent uses litellm, so any of these backends work — pick whichever you have.

ANTHROPIC_API_KEY=
# GEMINI_API_KEY=          # free tier: aistudio.google.com
# GROQ_API_KEY=            # free tier: console.groq.com
# OPENROUTER_API_KEY=      # some free models: openrouter.ai

# Optional overrides:
# MODEL=anthropic/claude-haiku-4-5    # or gemini/gemini-2.0-flash, groq/llama-3.3-70b-versatile, ollama/llama3.1
# APPWORLD_EXPERIMENT=team_yourname
# APPWORLD_DATASET=dev
# MAX_TASKS=0
# MAX_INTERACTIONS=30
